{
  "name": "aigency",
  "version": "0.2.0",
  "type": "module",
  "description": "Shop real brand catalogs from your terminal. An AI shopping assistant, as a CLI — braille product art and all.",
  "bin": {
    "aigency": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/cli.js",
    "preview": "tsx scripts/preview.tsx",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aigencyai/aigency-cli.git"
  },
  "homepage": "https://github.com/aigencyai/aigency-cli#readme",
  "bugs": {
    "url": "https://github.com/aigencyai/aigency-cli/issues"
  },
  "keywords": [
    "cli",
    "tui",
    "ink",
    "shopping",
    "ai",
    "terminal",
    "aigency",
    "braille",
    "react"
  ],
  "license": "MIT",
  "author": "Aigency",
  "dependencies": {
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
